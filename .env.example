# =============================================================================
# FOND COEUR D'OR — Variables d'environnement
# Copier ce fichier en .env.local et renseigner les valeurs réelles.
# Sur Vercel : Settings > Environment Variables (mêmes clés).
# =============================================================================

# URL du projet Supabase (Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# Clé publique anonyme (Settings > API > anon public) — exposée côté client
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Clé service_role (Settings > API > service_role) — SECRÈTE, jamais côté client
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Mot de passe simple protégeant la page /admin
ADMIN_PASSWORD=fco2026
